SECRET_KEY=your-secret-key-here
SUPABASE_URL=https://your-project-ref.supabase.co
# Optional legacy fallback only for projects still using HS256 JWT secret signing.
SUPABASE_JWT_SECRET=your-legacy-supabase-jwt-secret
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
PRODUCTION=1 # or 0
# Leave DATABASE_URL unset for local SQLite. Set it only when using PostgreSQL.
# DATABASE_URL=postgresql://user:password@localhost:5432/tppr
BACKEND_ALLOWED_ORIGINS=comma-separated-http-urls

VALID_ADMIN_EMAILS=comma-separated-emails
